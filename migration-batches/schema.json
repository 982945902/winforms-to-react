{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/wf2react/migration-batch.schema.json",
  "title": "WinForms migration batch",
  "type": "object",
  "required": ["id", "files"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "id": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repository": { "type": "string" },
        "revision": { "type": "string" }
      }
    },
    "actionContracts": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
      ]
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "\\.[Dd][Ee][Ss][Ii][Gg][Nn][Ee][Rr]\\.[Cc][Ss]$" }
    }
  }
}
